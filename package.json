{
  "name": "ludex",
  "version": "1.17.0",
  "description": "Ludex: apunta los juegos que quieres jugar y los que ya completaste, con nota, fecha y diario.",
  "author": "Jose Luis",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "pack": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.joselu.ludex",
    "productName": "Ludex",
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Xzorez",
        "repo": "ludex"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Ludex"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
